{
  "version": 1,
  "timezone": "Asia/Tokyo",
  "delivery": {
    "channel": "discord",
    "to": "1483636573235843072",
    "accountId": "default",
    "mode": "announce"
  },
  "jobs": [
    {
      "name": "news-digest-jst-0900",
      "description": "Discord news digest for previous 16 hours (JST)",
      "schedule": {
        "expr": "0 9 * * *",
        "tz": "Asia/Tokyo"
      },
      "windowLabel": "前一日 17:00 到当日 09:00（亚洲/东京，JST）",
      "windowHours": 16
    },
    {
      "name": "news-digest-jst-1700",
      "description": "Discord news digest for 09:00-17:00 (JST)",
      "schedule": {
        "expr": "0 17 * * *",
        "tz": "Asia/Tokyo"
      },
      "windowLabel": "当日 09:00 到当日 17:00（亚洲/东京，JST）",
      "windowHours": 8
    }
  ],
  "formatRules": {
    "titleLine": "新闻简报",
    "showWindowAsPlainLine": true,
    "outline": [
      "**1. 日本**",
      "**2. 中国**",
      "**3. 国际**",
      "**4. 市场或风险提示**"
    ],
    "contentBulletPrefix": "• ",
    "forbidNestedNumbering": true,
    "selfCheckNumberedLinesOnlyTopLevel": true,
    "requirePerItemSourceLink": true,
    "fallbackNoMajorUpdateLine": "本节无合格新增新闻条目。",
    "requireLinkOnNewLine": true,
    "requireSourceLinkMatchesItem": true,
    "forbidAggregatorLinksAsSource": true,
    "requireSourceVerifiedBeforeWriting": true,
    "omitFinalSourceSummary": true
  },
  "runtimeReadiness": {
    "rssReachabilityHosts": [
      "feeds.reuters.com",
      "www.reuters.com",
      "www.apnews.com",
      "feeds.bbci.co.uk",
      "feeds.npr.org"
    ]
  },
  "sourcePolicy": {
    "rssFeedHints": [
      "Reuters：主站 RSS 常用路径（不依赖 feeds 子域解析）如 https://www.reuters.com/rssfeed/worldNews 、 https://www.reuters.com/rssfeed/topNews",
      "AP： https://apnews.com/apf-topnews（聚合页；请打开单篇报道取可验证直链）",
      "BBC： https://feeds.bbci.co.uk/news/world/rss.xml",
      "NPR： https://feeds.npr.org/1001/rss.xml"
    ],
    "rssFeedsByBatch": {
      "japan": [
        "https://www.japantimes.co.jp/feed/",
        "https://www3.nhk.or.jp/rss/news/cat0.xml",
        "https://feeds.reuters.com/reuters/worldNews",
        "https://feeds.bbci.co.uk/news/world/asia/rss.xml"
      ],
      "china": [
        "https://feeds.bbci.co.uk/news/world/asia/china/rss.xml",
        "https://feeds.reuters.com/reuters/worldNews",
        "https://www.cnbc.com/id/100727362/device/rss/rss.html"
      ],
      "world": [
        "https://feeds.reuters.com/reuters/topNews",
        "https://feeds.reuters.com/reuters/worldNews",
        "https://feeds.bbci.co.uk/news/world/rss.xml",
        "https://feeds.npr.org/1001/rss.xml"
      ],
      "markets": [
        "https://feeds.reuters.com/reuters/businessNews",
        "https://feeds.bbci.co.uk/news/business/rss.xml",
        "https://www.cnbc.com/id/10001147/device/rss/rss.html"
      ]
    },
    "priorityKeywords": [
      "president",
      "assassination",
      "shooting",
      "attack",
      "threat",
      "terror",
      "war",
      "election",
      "总统",
      "刺杀",
      "枪击",
      "袭击",
      "战争",
      "恐袭"
    ],
    "marketKeywords": [
      "market",
      "stock",
      "shares",
      "earnings",
      "oil",
      "currency",
      "inflation",
      "central bank",
      "央行",
      "股价",
      "市场",
      "油价",
      "通胀"
    ],
    "regionKeywordsByBatch": {
      "japan": [
        "japan",
        "japanese",
        "日本",
        "日元",
        "东京",
        "大阪",
        "tokyo",
        "osaka",
        "kyoto",
        "hokkaido",
        "yen",
        "nikkei",
        "jpx"
      ],
      "china": [
        "china",
        "chinese",
        "中国",
        "北京",
        "上海",
        "人民币",
        "beijing",
        "shanghai",
        "shenzhen",
        "hong kong",
        "hongkong",
        "taiwan",
        "yuan",
        "renminbi"
      ]
    },
    "minRegionalItems": 1,
    "maxArticlesPerBatch": 12,
    "blockedDomains": [
      "theguardian.com",
      "www.theguardian.com"
    ],
    "aggregatorDomains": [
      "news.google.com",
      "google.com",
      "news.yahoo.com",
      "yahoo.com"
    ],
    "coverageCategories": [
      "时政与公共事务",
      "经济与产业",
      "社会与民生",
      "科技与AI",
      "文化与娱乐",
      "体育与生活方式",
      "公共安全与健康",
      "环境与气候"
    ],
    "coverageRule": "不能只保留国家级或宏观政治经济新闻；每次都要主动检索并纳入有信息价值的社会、娱乐、科技、文化、生活类新闻。",
    "minimumSoftNewsCategoriesPerRegion": 2,
    "sourcePools": {
      "japan": [
        "Reuters",
        "AP",
        "Kyodo",
        "The Japan Times",
        "nippon.com",
        "Formula 1",
        "The Cut",
        "Vanity Fair",
        "ESPN"
      ],
      "china": [
        "Reuters",
        "BBC",
        "CNBC",
        "NBC News",
        "SpaceNews",
        "InsideEVs",
        "The New York Times",
        "AP"
      ],
      "world": [
        "Reuters",
        "AP",
        "WMO",
        "WHO",
        "ICIJ",
        "NPR",
        "BBC",
        "ESPN",
        "AP News"
      ]
    }
  },
  "toolPolicy": {
    "preferWebSearchAndWebFetch": true,
    "forbidBrowserSearchPages": true,
    "browserFallbackPolicy": "如果 browser 超时或不可用，不要重试 browser；直接改走 web_search、RSS、媒体直链与公开网页抓取。",
    "searchQuotaPolicy": {
      "rssFirst": true,
      "primaryProvider": "brave",
      "limits": {
        "brave": {
          "period": "monthly",
          "maxCalls": 1000
        }
      },
      "enforcementRules": [
        "每次任务优先使用 RSS、原媒体直链和已知权威页面，只有确实需要补线索时才调用搜索 API。",
        "调用 Brave 前必须确认本月累计调用未超过 1000 次；达到上限后本月不得再调用 Brave。",
        "当 Brave 达到上限时，只能降级到 RSS、原媒体直链与公开网页抓取，不得继续硬打超限 provider。",
        "执行过程中必须精确控制调用量，不得为了同一条新闻重复进行无意义的同类搜索。"
      ]
    }
  },
  "model": {
    "chatPrimary": "openai-codex/gpt-5.5",
    "chatFallback": "ollama/qwen3:14b",
    "chatEscalateWhenHistoryCharsExceed": 15000,
    "codexBaseUrl": "http://127.0.0.1:49530/v1",
    "codexApiKeyEnv": "NEWS_CODEX_API_KEY",
    "ollamaBaseUrl": "http://ccnode.briconbric.com:22545",
    "ollamaNote": "Ollama 仅在 ccnode 节点运行；宿主机无本地 Ollama，localhost:11434 上的是云端代理不可用于本地推理",
    "newsOrchestrator": "openai-codex/gpt-5.5",
    "newsWorker": "openai-codex/gpt-5.5",
    "newsFinalize": "openai-codex/gpt-5.5",
    "newsFinalizeNote": "Codex 作为新闻编排、逐条处理与终稿格式化主模型；Qwen/Ollama 仅作为兜底。",
    "workerCallMode": "per-article",
    "maxWorkerInputChars": 1500,
    "thinking": "low",
    "timeoutSeconds": 3600,
    "lightContext": true,
    "allowUnsafeExternalContent": true,
    "qwenUsagePolicy": {
      "role": "processor",
      "summary": "Codex handles all primary tasks; Qwen/Ollama is fallback only.",
      "allowedScenarios": [
        "逐条新闻摘要与结构化整理",
        "单条分类与格式校验",
        "与 Discord 交互的任务控制 (task_control与news_task)",
        "中长对话（history < 15000 chars）",
        "中间稿压缩与提取"
      ],
      "forbiddenScenarios": [
        "大任务整包跨时区聚合直出（超过 24 小时的数据一次性汇总）"
      ]
    }
  },
  "newsExecution": {
    "mode": "pipeline",
    "repoPath": "/var/lib/openclaw/repos/SpringMonkey",
    "cronTimeoutSeconds": 7200,
    "crossRunDedupeHours": 12,
    "requireTimestampInWindow": false,
    "pipelineCliArgs": []
  }
}
